{
  "name": "nanocode",
  "version": "0.1.0",
  "description": "A lightweight AI assistant that runs OpenCode agents in containers. Connects to WhatsApp, Telegram, and more.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest",
    "setup": "tsx scripts/setup.ts"
  },
  "keywords": [
    "ai",
    "assistant",
    "opencode",
    "whatsapp",
    "telegram",
    "chatbot",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1014.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.7.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.31.0",
    "nanoid": "^5.0.9",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/gapi": "^0.0.47",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
