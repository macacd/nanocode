# ============================================================================
# NanoCode Configuration
# ============================================================================

# Trigger word - the bot responds to messages containing this word
TRIGGER_WORD=@Andy

# Default model for OpenCode agents
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# Maximum concurrent agent containers
MAX_CONCURRENT_AGENTS=3

# Message processing timeout (ms)
MESSAGE_TIMEOUT=120000

# Container runtime: 'docker' or 'none'
CONTAINER_RUNTIME=docker

# ============================================================================
# LLM Provider API Keys (at least one required)
# ============================================================================

# Anthropic API Key
ANTHROPIC_API_KEY=

# OpenAI API Key (optional)
OPENAI_API_KEY=

# OpenCode Zen API Key (optional)
# Get one at: https://opencode.ai/auth
OPENCODE_ZEN_API_KEY=

# ============================================================================
# Channel Configuration
# ============================================================================

# WhatsApp
# Set to 'true' to enable WhatsApp. QR code will be shown on first run.
WHATSAPP_ENABLED=false

# Telegram
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID for admin access (optional)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_ADMIN_ID=

# Discord (coming soon)
# DISCORD_BOT_TOKEN=

# Slack (coming soon)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
